{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and exchange configuration.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "referralCode": { "type": "string" },
        "referralCount": { "type": "number" },
        "referralEarnings": { "type": "number" },
        "exchanges": {
          "type": "object",
          "properties": {
            "binance": {
              "type": "object",
              "properties": {
                "apiKey": { "type": "string" },
                "secret": { "type": "string" }
              }
            },
            "okx": {
              "type": "object",
              "properties": {
                "apiKey": { "type": "string" },
                "secret": { "type": "string" },
                "password": { "type": "string" }
              }
            }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
            "defaultStopLoss": { "type": "number" },
            "defaultTakeProfit": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A recorded trade execution.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "exchange": { "type": "string" },
        "symbol": { "type": "string" },
        "side": { "type": "string", "enum": ["buy", "sell"] },
        "amount": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed", "cancelled"] },
        "pnl": { "type": "number" },
        "type": { "type": "string", "enum": ["manual", "auto"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "stopLoss": { "type": "number" },
        "takeProfit": { "type": "number" }
      },
      "required": ["userId", "exchange", "symbol", "side", "amount", "price", "status"]
    },
    "Signal": {
      "title": "Signal",
      "description": "AI-generated trading signal.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "recommendation": { "type": "string", "enum": ["buy", "sell", "hold"] },
        "confidence": { "type": "number" },
        "reasoning": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "recommendation", "confidence", "timestamp"]
    },
    "Bot": {
      "title": "Bot",
      "description": "Automated trading bot configuration.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "strategy": { "type": "string" },
        "isActive": { "type": "boolean" },
        "symbol": { "type": "string" },
        "allocation": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "strategy", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and encrypted exchange keys."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Trade history for a user."
    },
    "/users/{userId}/bots/{botId}": {
      "schema": "Bot",
      "description": "User's automated bots."
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Public signals (visible to all users but generated by server)."
    }
  }
}
